{
  "name": "insider-tracker-worker",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "SEC Form 4 ingestion worker — fetches EDGAR filings and writes them to Supabase.",
  "scripts": {
    "ingest": "tsx src/index.ts",
    "ingest:days": "tsx src/index.ts --days",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.45.4",
    "fast-xml-parser": "^4.5.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
