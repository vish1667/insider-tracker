# --- Supabase ---
# Project URL, e.g. https://abcdefgh.supabase.co
SUPABASE_URL=

# Use the SERVICE ROLE key here (worker writes data, bypasses RLS).
# Find it in: Supabase dashboard > Project Settings > API > service_role.
# NEVER expose this key in the frontend or commit it.
SUPABASE_SERVICE_ROLE_KEY=

# --- SEC EDGAR ---
# REQUIRED by SEC. Must identify you with a real name + email, e.g.
# "Insider Tracker (personal research) you@example.com"
# Requests without a descriptive User-Agent can be throttled or blocked.
SEC_USER_AGENT=Insider Tracker personal-research your-email@example.com
